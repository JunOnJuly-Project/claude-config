{
  "hooks": {
    "SessionStart": [
      {
        "type": "prompt",
        "prompt": "세션이 시작되었습니다. 모든 응답/주석/커밋은 한국어. 현재 디렉터리가 프로젝트면 **첫 작업으로 /bootstrap 을 호출**하여 HANDOFF/브랜치/빌드 상태를 검증하세요. CLAUDE.md 의 클린코드·깃·에이전트 팀 규칙을 준수하세요."
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "코드 작성 전 확인: 1) 한국어 주석 포함 2) 함수 20줄 이내 3) 매개변수 3개 이내 4) 매직넘버 없음 5) SOLID 원칙 준수"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(node *)",
      "Bash(ts-node *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(pipenv *)",
      "Bash(poetry *)",
      "Bash(pytest *)",
      "Bash(jest *)",
      "Bash(vitest *)",
      "Bash(mocha *)",
      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(gradle *)",
      "Bash(mvn *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(env *)",
      "Bash(export *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(diff *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(halt *)",
      "Bash(poweroff *)",
      "Bash(format *)",
      "Bash(mkfs *)",
      "Bash(mkfs.*)",
      "Bash(dd if=*)",
      "Bash(:(){ *)",
      "Bash(chmod -R 777 /*)",
      "Bash(chown -R *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease origin main*)",
      "Bash(git push * main --force*)",
      "Bash(git push * master --force*)",
      "Bash(git reset --hard origin/main*)",
      "Bash(git reset --hard origin/master*)",
      "Bash(git config --global *)",
      "Bash(git filter-branch *)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(cargo publish*)",
      "Bash(pip install --break-system-packages*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*secret*)",
      "Read(**/*credentials*)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Read(**/id_ed25519)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.netrc)",
      "Read(**/.pypirc)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/.ssh/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/.ssh/**)"
    ]
  }
}
