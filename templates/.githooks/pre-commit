#!/bin/sh
# pre-commit: 시크릿/빌드 산출물 커밋 차단
set -e

BLOCKED='(\.env$|\.env\.|infra/secrets/|\.pem$|\.key$|id_rsa|node_modules/|build/|target/|\.next/|dist/)'
STAGED=$(git diff --cached --name-only)

if echo "$STAGED" | grep -E "$BLOCKED" >/dev/null; then
  echo "[pre-commit] 차단: 시크릿 또는 빌드 산출물 감지"
  echo "$STAGED" | grep -E "$BLOCKED"
  exit 1
fi

exit 0
